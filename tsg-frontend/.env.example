# Backend API (Azure Container App FQDN — get from: pulumi stack output container_app_fqdn)
NEXT_PUBLIC_API_URL=https://tsg-backend-prod.azurecontainerapps.io

# Supabase (public keys — safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Dev bypass — MUST be false in production (bypasses Supabase auth entirely)
NEXT_PUBLIC_DEV_BYPASS=false
